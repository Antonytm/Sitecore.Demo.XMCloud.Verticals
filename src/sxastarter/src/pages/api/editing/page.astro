---
import JssLayout from "./../../../layouts/JssLayout.astro";

let body;
let path;
let layoutData;
let dictionary;
try {
  body = await Astro.request.json();
  path = body.args[0];
  layoutData = JSON.parse(body.args[1]);
  dictionary = JSON.parse(body.args[2]);
} catch (error) {
  //console.error(error);
}
---

{
  layoutData && <JssLayout title="a" layoutData={layoutData} />
}
